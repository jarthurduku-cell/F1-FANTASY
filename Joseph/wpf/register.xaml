<Page x:Class="WPF.register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0B0B0B">

    <Grid>
        <!-- Background -->
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#1A0000" Offset="0"/>
                <GradientStop Color="#000000" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Scaler -->
        <Viewbox Stretch="Uniform">

            <!-- Fixed design size -->
            <Grid Width="1000" Height="700">

                <!-- Card -->
                <Border Width="393"
                        Padding="25"
                        Background="#1C1C1E"
                        CornerRadius="12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top" Height="460" Margin="308,112,0,0">

                    <StackPanel>

                        <TextBlock Text="Build your ultimate racing team"
                                   Foreground="Gray"
                                   Margin="0,5,0,20"
                                   HorizontalAlignment="Center"/>

                        <!-- Inputs -->
                        <TextBox Text="Full Name" Margin="0,5" Padding="12"
                                 Background="#2A2A2A" Foreground="Gray" BorderThickness="0"/>

                        <TextBox Text="your.email@example.com" Margin="0,5" Padding="12"
                                 Background="#2A2A2A" Foreground="Gray" BorderThickness="0"/>

                        <PasswordBox Margin="0,5" Padding="12"
                                     Background="#2A2A2A" BorderThickness="0"/>
                        <Button Content="Sign Up"
                                Background="#E10600"
                                Foreground="White"
                                Height="45" Click="Button_Click_SignIN"
                                />

                    </StackPanel>
                </Border>
                <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Center" Height="74" Margin="0,24,0,0" VerticalAlignment="Top" Width="372" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="1.13"/>
                            <RotateTransform Angle="-0.052"/>
                            <TranslateTransform X="0.009" Y="0.01"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <TextBlock Text="F1 FANTASY"
                        Foreground="White"
                        FontSize="30
"
                        FontWeight="Bold"
                                   Margin="100,1,70,27" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleX="0.203"/>
                                <RotateTransform/>
                                <TranslateTransform X="0.073"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Border>

            </Grid>
        </Viewbox>
        <TextBlock Text="Build your ultimate racing team"
            Foreground="Gray"
                                   Margin="419,70,414,614"/>
    </Grid>
</Page>