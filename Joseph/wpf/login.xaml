<Window x:Class="WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Fantasy" Height="780" Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0A0A0A"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- Input field style -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="38 0 12 0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="38 0 12 0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red Sign In Button -->
        <Style x:Key="SignInButton" TargetType="Button">
            <Setter Property="Background" Value="#E8001D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C8001A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#A80016"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Social Button -->
        <Style x:Key="SocialButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link Button -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8001D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A0000" Offset="0"/>
                <GradientStop Color="#0A0A0A" Offset="0.5"/>
                <GradientStop Color="#1A0005" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Top-left red glow -->
        <Ellipse Width="420" Height="420"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-160 -160 0 0" Opacity="0.3">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#CC0000" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Bottom-right red glow -->
        <Ellipse Width="420" Height="420"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0 0 -160 -160" Opacity="0.2">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#CC0000" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Page Layout -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="480">

            <!-- App Title -->
            <TextBlock Text="F1 FANTASY"
                       FontSize="34" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 8"/>

            <TextBlock Text="Build your ultimate racing team"
                       FontSize="14" Foreground="#777777"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 32"/>

            <!-- Login Card -->
            <Border Background="#1C1C1C" CornerRadius="12" Padding="36 32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Welcome Back"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White" Margin="0 0 0 24"/>

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="13" Foreground="#BBBBBB" Margin="0 0 0 6"/>
                    <Grid Height="46" Margin="0 0 0 16">
                        <TextBox x:Name="EmailBox"
                                 Style="{StaticResource InputField}"
                                 Padding="38 0 12 0"
                                 TextChanged="EmailBox_TextChanged"/>
                        <TextBlock Text="✉" FontSize="14" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="12 0 0 0"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="EmailPlaceholder"
                                   Text="jarthurduku@gmail.com"
                                   FontSize="14" Foreground="#555555"
                                   VerticalAlignment="Center" Margin="40 0 0 0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password -->
                    <TextBlock Text="Password" FontSize="13" Foreground="#BBBBBB" Margin="0 0 0 6"/>
                    <Grid Height="46" Margin="0 0 0 14">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource PasswordField}"
                                     Padding="38 0 12 0"/>
                        <TextBlock Text="🔒DukuJoseph@123" FontSize="13" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="12 0 0 0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Remember Me + Forgot Password -->
                    <Grid Margin="0 0 0 20">
                        <CheckBox x:Name="RememberMeCheck"
                                  Content="Remember me"
                                  Foreground="#AAAAAA" FontSize="13"
                                  VerticalContentAlignment="Center" Checked="RememberMeCheck_Checked"/>
                        <Button Content="Forgot password?"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="ForgotPassword_Click" />
                    </Grid>

                    <!-- Sign In Button -->
                    <Button Content="Sign In"
                            Style="{StaticResource SignInButton}"
                            Height="46"
                            Margin="0 0 0 20"
                            Click="SignIn_Click"/>

                    <!-- OR Divider -->
                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Separator Grid.Column="0" Background="#333333" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="OR" FontSize="12"
                                   Foreground="#555555" Margin="12 0"/>
                        <Separator Grid.Column="2" Background="#333333" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Google -->
                    <Button Style="{StaticResource SocialButton}" Height="46" Margin="0 0 0 10"
                            Click="GoogleLogin_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="G" FontWeight="Bold" FontSize="15"
                                       Foreground="#CCCCCC" Margin="0 0 10 0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Continue with Google" Foreground="#CCCCCC"
                                       FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- GitHub -->
                    <Button Style="{StaticResource SocialButton}" Height="46" Margin="0 0 0 24"
                            Click="GitHubLogin_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="15" Foreground="#CCCCCC"
                                       Margin="0 0 10 0" VerticalAlignment="Center"/>
                            <TextBlock Text="Continue with GitHub" Foreground="#CCCCCC"
                                       FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Sign Up -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? "
                                   Foreground="#777777" FontSize="14"/>
                        <Button Content="Sign up now"
                                Style="{StaticResource LinkButton}"
                                FontWeight="SemiBold"
                                Click="SignUp_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>



            <!-- Footer -->
            <TextBlock Text="© 2026 F1 Fantasy. All rights reserved."
                       FontSize="12" Foreground="#444444"
                       HorizontalAlignment="Center" Margin="0 20 0 0"/>
        </StackPanel>
    </Grid>
</Window>
