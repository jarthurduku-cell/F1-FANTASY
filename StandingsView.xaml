<UserControl x:Class="F1Fantasy.Views.StandingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">
    <UserControl.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="BorderBrush" Value="#222226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888898"/>
        </Style>

        <Style x:Key="BigNum" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#F0EEEA"/>
        </Style>

        <Style x:Key="ColHdr" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555560"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#E8002D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E47"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="18,14,18,24">

            <!-- ── LEAGUE HEADER ── -->
            <Border Style="{StaticResource Card}" Padding="22,18" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Office Champions League"
                                   FontFamily="Segoe UI Black" FontSize="22" FontWeight="Black"
                                   Foreground="#F0EEEA"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="👥" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="24 Members" Style="{StaticResource Lbl}" Margin="0,0,12,0"/>
                            <TextBlock Text="📅" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Race 8 of 23"  Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                            <TextBlock Text="•"             Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                            <TextBlock Text="Monaco GP Complete"
                                       FontFamily="Segoe UI Semibold" FontSize="11" Foreground="#E8002D"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="View My Team"
                            Style="{StaticResource BtnRed}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── 4 STAT CARDS ── -->
            <UniformGrid Columns="4" Margin="0,0,0,14">
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="Your Position" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="3rd"            Style="{StaticResource BigNum}" Margin="0,5,0,0"/>
                        <TextBlock Text="↑ 1 place"      FontSize="11" Foreground="#4CAF50" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Your Points"  Style="{StaticResource Lbl}"/>
                        <TextBlock Text="2,756"        Style="{StaticResource BigNum}" Margin="0,5,0,0"/>
                        <TextBlock Text="+167 last race" FontSize="11" Foreground="#4CAF50" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Gap to Leader"  Style="{StaticResource Lbl}"/>
                        <TextBlock Text="91"             Style="{StaticResource BigNum}" Margin="0,5,0,0"/>
                        <TextBlock Text="points behind"  Style="{StaticResource Lbl}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Average Points" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="345"            Style="{StaticResource BigNum}" Margin="0,5,0,0"/>
                        <TextBlock Text="per race"       Style="{StaticResource Lbl}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── STANDINGS TABLE ── -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>

                    <!-- Table top bar -->
                    <Grid Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="League Standings"
                                   FontFamily="Segoe UI Semibold" FontSize="15"
                                   Foreground="#F0EEEA" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#1A1A1C"
                                BorderBrush="#333336" BorderThickness="1" CornerRadius="4"
                                Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Bahrain GP" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#F0EEEA" VerticalAlignment="Center"/>
                                <TextBlock Text="  ▾" FontSize="10" Foreground="#888898"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Column headers -->
                    <Border Background="#0D0D0F" Padding="20,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>    <!-- pos -->
                                <ColumnDefinition Width="46"/>    <!-- avatar -->
                                <ColumnDefinition Width="*"/>     <!-- name -->
                                <ColumnDefinition Width="110"/>   <!-- total pts -->
                                <ColumnDefinition Width="90"/>    <!-- last race -->
                                <ColumnDefinition Width="80"/>    <!-- trend -->
                                <ColumnDefinition Width="240"/>   <!-- history -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pos"          Style="{StaticResource ColHdr}"/>
                            <TextBlock Grid.Column="2" Text="Player"       Style="{StaticResource ColHdr}"/>
                            <TextBlock Grid.Column="3" Text="Total Points" Style="{StaticResource ColHdr}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="Last Race"    Style="{StaticResource ColHdr}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="5" Text="Trend"        Style="{StaticResource ColHdr}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="Race History" Style="{StaticResource ColHdr}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Rows -->
                    <ItemsControl x:Name="StandingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RowBg}" Padding="20,0">
                                    <!-- separator line -->
                                    <StackPanel>
                                        <Grid MinHeight="54">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="46"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="240"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Pos + medal -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Medal}"
                                                           FontSize="13" Margin="0,0,4,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Pos}"
                                                           FontFamily="Segoe UI Black" FontSize="15"
                                                           FontWeight="Black"
                                                           Foreground="{Binding PosColor}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Avatar circle -->
                                            <Border Grid.Column="1" Width="34" Height="34"
                                                    CornerRadius="17"
                                                    Background="{Binding AvatarBrush}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Initials}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe UI Black"
                                                           FontSize="11" Foreground="White"/>
                                            </Border>

                                            <!-- Name + "You" tag -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="13" Foreground="#F0EEEA"/>
                                                <TextBlock Text="You" FontSize="10"
                                                           Foreground="#E8002D"
                                                           Visibility="{Binding YouVis}"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <!-- Total Points -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding TotalPts}"
                                                       FontFamily="Segoe UI Black" FontSize="17"
                                                       FontWeight="Black" Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>

                                            <!-- Last Race -->
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding LastRace}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>

                                            <!-- Trend -->
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Trend}"
                                                       FontFamily="Segoe UI Semibold"
                                                       FontSize="12"
                                                       Foreground="{Binding TrendBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- History chips -->
                                            <ItemsControl Grid.Column="6"
                                                          ItemsSource="{Binding Chips}"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" Margin="2,0"
                                                                Background="{Binding Bg}"
                                                                Padding="6,3">
                                                            <TextBlock Text="{Binding Val}"
                                                                       FontFamily="Segoe UI Semibold"
                                                                       FontSize="10"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </Grid>
                                        <Rectangle Height="1" Fill="#1A1A1E"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
