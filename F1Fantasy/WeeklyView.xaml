<UserControl x:Class="F1Fantasy.Views.WeeklyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="BorderBrush" Value="#222226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888898"/>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#E8002D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E47"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1C"/>
            <Setter Property="Foreground" Value="#888898"/>
            <Setter Property="BorderBrush" Value="#333336"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0EEEA"/>
                                <Setter Property="BorderBrush" Value="#555560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,14,18,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="310"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT COLUMN ══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- race header -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>  <!-- how to play -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>     <!-- prediction list -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>  <!-- submit -->
            </Grid.RowDefinitions>

            <!-- RACE HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>

                <!-- Race name card -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16,14">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="8"
                                Background="#E8002D" Margin="0,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="📍" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Spanish Grand Prix"
                                       FontFamily="Segoe UI Black" FontSize="18"
                                       FontWeight="Black" Foreground="#F0EEEA"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="📅 " FontSize="11"/>
                                <TextBlock Text="Circuit de Barcelona  •  May 25-27, 2026"
                                           Style="{StaticResource Lbl}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Deadline countdown -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⏱ " FontSize="12" Foreground="#E8002D"/>
                            <TextBlock Text="Deadline"
                                       FontFamily="Segoe UI Semibold" FontSize="12"
                                       Foreground="#F0EEEA"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="2" FontFamily="Segoe UI Black" FontSize="22"
                                           FontWeight="Black" Foreground="#F0EEEA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Days" Style="{StaticResource Lbl}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="14" FontFamily="Segoe UI Black" FontSize="22"
                                           FontWeight="Black" Foreground="#F0EEEA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Hours" Style="{StaticResource Lbl}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="29" FontFamily="Segoe UI Black" FontSize="22"
                                           FontWeight="Black" Foreground="#F0EEEA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Min" Style="{StaticResource Lbl}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="48" FontFamily="Segoe UI Black" FontSize="22"
                                           FontWeight="Black" Foreground="#F0EEEA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Sec" Style="{StaticResource Lbl}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Streak -->
                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="🔥 " FontSize="12"/>
                            <TextBlock Text="Your Streak" Style="{StaticResource Lbl}"/>
                        </StackPanel>
                        <TextBlock Text="5"
                                   FontFamily="Segoe UI Black" FontSize="28"
                                   FontWeight="Black" Foreground="#F0EEEA"/>
                        <TextBlock Text="Weeks in a row"
                                   FontSize="10" Foreground="#4CAF50"/>
                    </StackPanel>
                </Border>

                <!-- Best Score -->
                <Border Grid.Column="6" Style="{StaticResource Card}" Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="📈 " FontSize="12"/>
                            <TextBlock Text="Best Score" Style="{StaticResource Lbl}"/>
                        </StackPanel>
                        <TextBlock Text="78"
                                   FontFamily="Segoe UI Black" FontSize="28"
                                   FontWeight="Black" Foreground="#F0EEEA"/>
                        <TextBlock Text="Monaco GP" Style="{StaticResource Lbl}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- HOW TO PLAY -->
            <Border Grid.Row="2" Background="#0D0005"
                    BorderBrush="#2A0010" BorderThickness="1" CornerRadius="4" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="🎯 " FontSize="12" Foreground="#E8002D"/>
                            <TextBlock Text="How to Play"
                                       FontFamily="Segoe UI Semibold" FontSize="12"
                                       Foreground="#F0EEEA"/>
                        </StackPanel>
                        <TextBlock Text="Rank your top 10 drivers by dragging them into your predicted finishing order. Points are awarded based on accuracy (10 points for exact match, decreasing by 1 for each position off). Submit before Thursday to participate!"
                                   FontSize="11" Foreground="#888898"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Potential Points" Style="{StaticResource Lbl}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="22"
                                   FontFamily="Segoe UI Black" FontSize="26"
                                   FontWeight="Black" Foreground="#4CAF50"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PREDICTION LIST -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="16,14,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆 " FontSize="13" Foreground="#E8002D"/>
                            <TextBlock Text="Your Top 10 Prediction"
                                       FontFamily="Segoe UI Semibold" FontSize="13"
                                       Foreground="#F0EEEA" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Drag to reorder your predictions"
                                       Style="{StaticResource Lbl}" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <Border Background="#1A1A1C" BorderBrush="#333336"
                                    BorderThickness="1" CornerRadius="4" Padding="10,5">
                                <TextBlock Text="5/10 Drivers"
                                           FontFamily="Segoe UI Semibold" FontSize="11"
                                           Foreground="#F0EEEA"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1A1A1E"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                        <ItemsControl x:Name="PredictionList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1A1A1E" BorderThickness="0,0,0,1"
                                            Background="#111113" Padding="14,0" Cursor="SizeAll">
                                        <Grid MinHeight="60">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>  <!-- drag handle -->
                                                <ColumnDefinition Width="36"/>  <!-- pred pos -->
                                                <ColumnDefinition Width="50"/>  <!-- badge -->
                                                <ColumnDefinition Width="*"/>   <!-- name -->
                                                <ColumnDefinition Width="70"/>  <!-- current -->
                                                <ColumnDefinition Width="70"/>  <!-- last race -->
                                                <ColumnDefinition Width="160"/> <!-- form chips -->
                                                <ColumnDefinition Width="60"/>  <!-- points -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Drag handle -->
                                            <TextBlock Grid.Column="0" Text="⠿"
                                                       FontSize="16" Foreground="#333336"
                                                       VerticalAlignment="Center"/>

                                            <!-- Predicted position -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PredPos}"
                                                       FontFamily="Segoe UI Black" FontSize="16"
                                                       FontWeight="Black"
                                                       Foreground="{Binding PosColor}"
                                                       VerticalAlignment="Center"/>

                                            <!-- Number badge -->
                                            <Border Grid.Column="2" Width="38" Height="38"
                                                    CornerRadius="4"
                                                    Background="{Binding TeamColor}"
                                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Number}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe UI Black"
                                                           FontSize="14" Foreground="White"/>
                                            </Border>

                                            <!-- Name + Team -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="13" Foreground="#F0EEEA"/>
                                                <TextBlock Text="{Binding Team}"
                                                           FontSize="10" Foreground="#888898"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Current pos -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                <TextBlock Text="Current" Style="{StaticResource Lbl}"/>
                                                <TextBlock Text="{Binding CurrentPos}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="12" Foreground="#F0EEEA"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Last race -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                                <TextBlock Text="Last Race" Style="{StaticResource Lbl}"/>
                                                <TextBlock Text="{Binding LastRace}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="12" Foreground="#F0EEEA"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Form chips -->
                                            <StackPanel Grid.Column="6" VerticalAlignment="Center">
                                                <TextBlock Text="Form (Last 5)"
                                                           Style="{StaticResource Lbl}"
                                                           Margin="0,0,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Form}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="3" Margin="2,0"
                                                                    Background="{Binding Bg}" Padding="5,3">
                                                                <TextBlock Text="{Binding Val}"
                                                                           FontFamily="Segoe UI Semibold"
                                                                           FontSize="10" Foreground="White"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- Points -->
                                            <StackPanel Grid.Column="7" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="Points" Style="{StaticResource Lbl}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Points}"
                                                           FontFamily="Segoe UI Black" FontSize="15"
                                                           Foreground="#F0EEEA"
                                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- SUBMIT ROW -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Submit Predictions"
                        Style="{StaticResource BtnRed}" Padding="0,14"/>
                <Button Grid.Column="2" Content="Clear All"
                        Style="{StaticResource BtnGhost}" Padding="0,14"/>
            </Grid>

        </Grid>

        <!-- ══ RIGHT COLUMN ══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- AVAILABLE DRIVERS -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <StackPanel Margin="14,14,14,10">
                        <TextBlock Text="Available Drivers"
                                   FontFamily="Segoe UI Semibold" FontSize="13"
                                   Foreground="#F0EEEA"/>
                        <TextBlock Text="Click to add to your predictions"
                                   Style="{StaticResource Lbl}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Rectangle Height="1" Fill="#1A1A1E"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440">
                        <ItemsControl x:Name="AvailableList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1A1A1E" BorderThickness="0,0,0,1"
                                            Padding="12,10" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1A1A1C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="34" Height="34"
                                                    CornerRadius="4"
                                                    Background="{Binding TeamColor}">
                                                <TextBlock Text="{Binding Number}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe UI Black"
                                                           FontSize="12" Foreground="White"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                        Margin="10,0,8,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="12" Foreground="#F0EEEA"/>
                                                <TextBlock Text="{Binding Team}"
                                                           FontSize="10" Foreground="#888898"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        Margin="0,0,10,0">
                                                <TextBlock Text="Current" Style="{StaticResource Lbl}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding CurrentPos}"
                                                           FontFamily="Segoe UI Semibold" FontSize="11"
                                                           Foreground="#F0EEEA"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="3" Text="›"
                                                       FontSize="16" Foreground="#444448"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- QUICK REMOVE -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="Quick Remove"
                               FontFamily="Segoe UI Semibold" FontSize="12"
                               Foreground="#F0EEEA" Margin="0,0,0,10"/>
                    <WrapPanel x:Name="QuickRemovePanel"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
