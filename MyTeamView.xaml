<UserControl x:Class="F1Fantasy.Views.MyTeamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="BorderBrush" Value="#222226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888898"/>
        </Style>
        <Style x:Key="BigNum" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#F0EEEA"/>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#E8002D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E47"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888898"/>
            <Setter Property="BorderBrush" Value="#333336"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#F0EEEA"/>
                                <Setter Property="Foreground" Value="#F0EEEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="18,14,18,20">

            <!-- LEAGUE HEADER -->
            <Border Style="{StaticResource Card}" Padding="20,16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Office Champions League"
                                   FontFamily="Segoe UI Black" FontSize="22" FontWeight="Black"
                                   Foreground="#F0EEEA"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="👥" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="24 Members" Style="{StaticResource Lbl}" Margin="0,0,10,0"/>
                            <TextBlock Text="📅" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Race 8 of 23" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                            <TextBlock Text="•" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                            <TextBlock Text="Monaco GP Complete"
                                       FontFamily="Segoe UI Semibold" FontSize="11" Foreground="#E8002D"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Make Transfers"
                            Style="{StaticResource BtnRed}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 4 STAT CARDS -->
            <UniformGrid Columns="4" Margin="0,0,0,12">
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="Your Position" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="3rd" Style="{StaticResource BigNum}" Margin="0,4,0,0"/>
                        <TextBlock Text="↑ 1 place" FontSize="11" Foreground="#4CAF50" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Your Points" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="2,756" Style="{StaticResource BigNum}" Margin="0,4,0,0"/>
                        <TextBlock Text="+167 last race" FontSize="11" Foreground="#4CAF50" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="Gap to Leader" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="91" Style="{StaticResource BigNum}" Margin="0,4,0,0"/>
                        <TextBlock Text="points behind" Style="{StaticResource Lbl}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,14" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Average Points" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="345" Style="{StaticResource BigNum}" Margin="0,4,0,0"/>
                        <TextBlock Text="per race" Style="{StaticResource Lbl}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- TEAM BUDGET -->
            <Border Style="{StaticResource Card}" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Team Budget" FontFamily="Segoe UI Semibold"
                                   FontSize="14" Foreground="#F0EEEA" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✏  Edit Team" Style="{StaticResource BtnGhost}"/>
                    </Grid>
                    <!-- Numbers -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total Budget" Style="{StaticResource Lbl}"/>
                            <TextBlock Text="$100.0M" FontFamily="Segoe UI Black" FontSize="20"
                                       Foreground="#F0EEEA" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Spent" Style="{StaticResource Lbl}"/>
                            <TextBlock Text="$87.5M" FontFamily="Segoe UI Black" FontSize="20"
                                       Foreground="#F0EEEA" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Remaining" Style="{StaticResource Lbl}"/>
                            <TextBlock Text="$12.5M" FontFamily="Segoe UI Black" FontSize="20"
                                       Foreground="#4CAF50" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- Progress bar -->
                    <Grid Height="8" Background="#1A1A1C">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="875*"/>
                            <ColumnDefinition Width="125*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8002D" Offset="0"/>
                                    <GradientStop Color="#FF6B35" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- YOUR DRIVERS -->
            <Border Style="{StaticResource Card}" Padding="20,16">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Your Drivers" FontFamily="Segoe UI Semibold"
                                   FontSize="14" Foreground="#F0EEEA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="5 Drivers Selected"
                                   Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                    </Grid>

                    <ItemsControl x:Name="DriversList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" CornerRadius="4"
                                        Background="#1A1A1C" BorderBrush="#2A2A2E" BorderThickness="1">
                                    <Grid Margin="14,14,14,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Number badge -->
                                        <Border Grid.Column="0" Width="46" Height="46"
                                                CornerRadius="4" Background="{Binding TeamColor}">
                                            <TextBlock Text="{Binding Number}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Black" FontSize="17"
                                                       FontWeight="Black" Foreground="White"/>
                                        </Border>

                                        <!-- Name + Team -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Segoe UI Semibold" FontSize="14"
                                                       Foreground="#F0EEEA"/>
                                            <TextBlock Text="{Binding Team}"
                                                       FontSize="11" Foreground="#888898" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Price -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="Price" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Price}"
                                                       FontFamily="Segoe UI Semibold" FontSize="13"
                                                       Foreground="#F0EEEA" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Total Points -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="Total Points" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding TotalPoints}"
                                                       FontFamily="Segoe UI Black" FontSize="20"
                                                       Foreground="#F0EEEA" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Last Race -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="Last Race" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding LastRace}"
                                                       FontFamily="Segoe UI Semibold" FontSize="13"
                                                       Foreground="#4CAF50" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Edit pen -->
                                        <TextBlock Grid.Column="5" Text="✏" FontSize="14"
                                                   Foreground="#555560" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
