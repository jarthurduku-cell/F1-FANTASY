<UserControl x:Class="F1Fantasy.Views.TransfersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="BorderBrush" Value="#222226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888898"/>
        </Style>
        <Style x:Key="TabActive" TargetType="Button">
            <Setter Property="Background" Value="#E8002D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabInactive" TargetType="Button">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="#888898"/>
            <Setter Property="BorderBrush" Value="#222226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0EEEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#E8002D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E47"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnYellow" TargetType="Button">
            <Setter Property="Background" Value="#C9A84C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDB85A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1C"/>
            <Setter Property="Foreground" Value="#888898"/>
            <Setter Property="BorderBrush" Value="#333336"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0EEEA"/>
                                <Setter Property="BorderBrush" Value="#555560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#111113"/>
            <Setter Property="Foreground" Value="#F0EEEA"/>
            <Setter Property="BorderBrush" Value="#2A2A2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="36"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="18,14,18,14">

        <!-- ── 4 STAT CARDS ── -->
        <UniformGrid Columns="4" Margin="0,0,0,14">
            <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,5,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Transfer Budget" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="$45.0M" FontFamily="Segoe UI Black" FontSize="24"
                                   FontWeight="Black" Foreground="#F0EEEA" Margin="0,4,0,0"/>
                        <TextBlock Text="Available to spend" Style="{StaticResource Lbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="💵" FontSize="18" Opacity="0.35" VerticalAlignment="Top"/>
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Transfers Left" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="3" FontFamily="Segoe UI Black" FontSize="24"
                                   FontWeight="Black" Foreground="#F0EEEA" Margin="0,4,0,0"/>
                        <TextBlock Text="This gameweek" Style="{StaticResource Lbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="⚡" FontSize="18" Opacity="0.35" VerticalAlignment="Top"/>
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="18,14" Margin="3,0,3,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Squad Value" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="$38.5M" FontFamily="Segoe UI Black" FontSize="24"
                                   FontWeight="Black" Foreground="#F0EEEA" Margin="0,4,0,0"/>
                        <TextBlock Text="↑ $2.5M this week" FontSize="11" Foreground="#4CAF50" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="📈" FontSize="18" Opacity="0.35" VerticalAlignment="Top"/>
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="18,14" Margin="5,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Active Clauses" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="2" FontFamily="Segoe UI Black" FontSize="24"
                                   FontWeight="Black" Foreground="#F0EEEA" Margin="0,4,0,0"/>
                        <TextBlock Text="Protecting drivers" Style="{StaticResource Lbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="🔒" FontSize="18" Opacity="0.35" VerticalAlignment="Top"/>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- ── TAB BUTTONS ── -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnBuy" Grid.Column="0"
                    Content="🛒  Buy Drivers"
                    Style="{StaticResource TabActive}"
                    Padding="0,13" Margin="0,0,3,0"
                    Click="BtnBuy_Click"/>
            <Button x:Name="BtnSteal" Grid.Column="1"
                    Content="🎯  Steal Drivers"
                    Style="{StaticResource TabInactive}"
                    Padding="0,13" Margin="3,0,3,0"
                    Click="BtnSteal_Click"/>
            <Button x:Name="BtnMySquad" Grid.Column="2"
                    Content="👥  My Squad"
                    Style="{StaticResource TabInactive}"
                    Padding="0,13" Margin="3,0,0,0"
                    Click="BtnMySquad_Click"/>
        </Grid>

        <!-- ══════════════════════════════════════
             TAB: BUY DRIVERS
             ══════════════════════════════════════ -->
        <StackPanel x:Name="BuyPanel" Visibility="Visible">
            <!-- Filters -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Style="{StaticResource Combo}" SelectedIndex="0">
                    <ComboBoxItem>All Teams</ComboBoxItem>
                    <ComboBoxItem>Red Bull Racing</ComboBoxItem>
                    <ComboBoxItem>Ferrari</ComboBoxItem>
                    <ComboBoxItem>McLaren</ComboBoxItem>
                    <ComboBoxItem>Mercedes</ComboBoxItem>
                    <ComboBoxItem>Aston Martin</ComboBoxItem>
                </ComboBox>
                <ComboBox Grid.Column="2" Style="{StaticResource Combo}" SelectedIndex="0">
                    <ComboBoxItem>Sort by Points</ComboBoxItem>
                    <ComboBoxItem>Sort by Price</ComboBoxItem>
                    <ComboBoxItem>Sort by Name</ComboBoxItem>
                </ComboBox>
                <Border Grid.Column="4" Background="#1A1A1C" BorderBrush="#333336"
                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <TextBlock Text="5 Available" FontFamily="Segoe UI Semibold"
                               FontSize="12" Foreground="#F0EEEA"/>
                </Border>
            </Grid>

            <!-- Buy list -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <TextBlock Text="Available Drivers" FontFamily="Segoe UI Semibold"
                               FontSize="13" Foreground="#F0EEEA" Margin="18,14,18,12"/>
                    <Rectangle Height="1" Fill="#1A1A1E"/>
                    <ItemsControl x:Name="BuyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1A1A1E" BorderThickness="0,0,0,1"
                                        Background="#111113" Padding="16,0">
                                    <Grid MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Badge -->
                                        <Border Grid.Column="0" Width="48" Height="48"
                                                CornerRadius="4" Background="{Binding TeamColor}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Number}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Black" FontSize="16"
                                                       FontWeight="Black" Foreground="White"/>
                                        </Border>
                                        <!-- Name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="#F0EEEA"/>
                                            <TextBlock Text="{Binding Team}" FontSize="11"
                                                       Foreground="#888898" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Form chips -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Recent Form" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding Form}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" Margin="2,0"
                                                                Background="{Binding Bg}" Padding="6,3">
                                                            <TextBlock Text="{Binding Val}"
                                                                       FontFamily="Segoe UI Semibold"
                                                                       FontSize="10" Foreground="White"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <!-- Points -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Points" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Points}" FontFamily="Segoe UI Black"
                                                           FontSize="16" Foreground="#F0EEEA"/>
                                                <TextBlock Text="{Binding Trend}" FontSize="12"
                                                           Foreground="{Binding TrendColor}"
                                                           VerticalAlignment="Center" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Price -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Price" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Price}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Buy button -->
                                        <Button Grid.Column="5" Content="🛒  Buy"
                                                Style="{StaticResource BtnRed}"
                                                Padding="16,10" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════════════════════════════════
             TAB: STEAL DRIVERS
             ══════════════════════════════════════ -->
        <StackPanel x:Name="StealPanel" Visibility="Collapsed">
            <!-- How stealing works info -->
            <Border Background="#0D0005" BorderBrush="#2A0010" BorderThickness="1"
                    CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="ℹ " FontSize="12" Foreground="#E8002D"/>
                        <TextBlock Text="How Stealing Works" FontFamily="Segoe UI Semibold"
                                   FontSize="12" Foreground="#F0EEEA"/>
                    </StackPanel>
                    <TextBlock Text="You can steal drivers from other teams by paying their release clause (1.5x their price). Drivers with active release clauses cannot be stolen."
                               FontSize="11" Foreground="#888898" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <TextBlock Text="Owned Drivers" FontFamily="Segoe UI Semibold"
                               FontSize="13" Foreground="#F0EEEA" Margin="18,14,18,12"/>
                    <Rectangle Height="1" Fill="#1A1A1E"/>
                    <ItemsControl x:Name="StealList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1A1A1E" BorderThickness="0,0,0,1"
                                        Background="#111113" Padding="16,0">
                                    <Grid MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Badge -->
                                        <Border Grid.Column="0" Width="48" Height="48"
                                                CornerRadius="4" Background="{Binding TeamColor}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Number}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Black" FontSize="16"
                                                       FontWeight="Black" Foreground="White"/>
                                        </Border>
                                        <!-- Name + owner -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="#F0EEEA"/>
                                            <TextBlock Text="{Binding Team}" FontSize="11"
                                                       Foreground="#888898" Margin="0,1,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="👤 " FontSize="10"/>
                                                <TextBlock Text="{Binding Owner}" FontSize="10"
                                                           Foreground="#666670"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Form chips -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Recent Form" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding Form}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" Margin="2,0" Background="{Binding Bg}" Padding="6,3">
                                                            <TextBlock Text="{Binding Val}" FontFamily="Segoe UI Semibold" FontSize="10" Foreground="White"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <!-- Points -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Points" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Points}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Release Clause -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Release Clause" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Clause}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#C9A84C"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Steal button -->
                                        <Button Grid.Column="5" Content="🎯  Steal"
                                                Style="{StaticResource BtnYellow}"
                                                Padding="14,10" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════════════════════════════════
             TAB: MY SQUAD + CLAUSES
             ══════════════════════════════════════ -->
        <StackPanel x:Name="MySquadPanel" Visibility="Collapsed">
            <!-- Release clauses info -->
            <Border Background="#0D0005" BorderBrush="#2A0010" BorderThickness="1"
                    CornerRadius="4" Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🔒 " FontSize="12" Foreground="#E8002D"/>
                        <TextBlock Text="Release Clauses" FontFamily="Segoe UI Semibold"
                                   FontSize="12" Foreground="#F0EEEA"/>
                    </StackPanel>
                    <TextBlock Text="Activate release clauses to protect your drivers from being stolen. Clauses cost 10% of driver value per week."
                               FontSize="11" Foreground="#888898" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <TextBlock Text="Your Drivers" FontFamily="Segoe UI Semibold"
                               FontSize="13" Foreground="#F0EEEA" Margin="18,14,18,12"/>
                    <Rectangle Height="1" Fill="#1A1A1E"/>
                    <ItemsControl x:Name="MySquadList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1A1A1E" BorderThickness="0,0,0,1"
                                        Background="#111113" Padding="16,0">
                                    <Grid MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Badge + lock icon -->
                                        <Grid Grid.Column="0" VerticalAlignment="Center">
                                            <Border Width="48" Height="48" CornerRadius="4"
                                                    Background="{Binding TeamColor}">
                                                <TextBlock Text="{Binding Number}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI Black" FontSize="16"
                                                           FontWeight="Black" Foreground="White"/>
                                            </Border>
                                            <!-- Protected lock badge -->
                                            <Border Width="16" Height="16" CornerRadius="8"
                                                    Background="#4CAF50"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Visibility="{Binding ProtectedVis}">
                                                <TextBlock Text="🔒" FontSize="8"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <!-- Name + Protected badge -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                           FontSize="14" Foreground="#F0EEEA"/>
                                                <Border Background="#1A3A1A" BorderBrush="#2A5A2A"
                                                        BorderThickness="1" CornerRadius="3"
                                                        Padding="6,2" Margin="8,0,0,0"
                                                        Visibility="{Binding ProtectedVis}">
                                                    <TextBlock Text="Protected" FontFamily="Segoe UI Semibold"
                                                               FontSize="10" Foreground="#4CAF50"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Team}" FontSize="11"
                                                       Foreground="#888898" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Form chips -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Recent Form" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding Form}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" Margin="2,0" Background="{Binding Bg}" Padding="6,3">
                                                            <TextBlock Text="{Binding Val}" FontFamily="Segoe UI Semibold" FontSize="10" Foreground="White"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <!-- Points -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Points" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Points}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Value -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Value" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Value}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#F0EEEA"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Release Clause -->
                                        <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="Release Clause" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Clause}" FontFamily="Segoe UI Black"
                                                       FontSize="16" Foreground="#C9A84C"
                                                       HorizontalAlignment="Right" Margin="0,1,0,0"/>
                                            <TextBlock Text="{Binding ClauseCost}" FontSize="10"
                                                       Foreground="#666670" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                        <!-- Lock button -->
                                        <Button Grid.Column="6" Content="🔒"
                                                Style="{StaticResource BtnGhost}"
                                                Padding="8,10" VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                                        <!-- Sell button -->
                                        <Button Grid.Column="7" Content="👤  Sell"
                                                Style="{StaticResource BtnGhost}"
                                                Padding="12,10" VerticalAlignment="Center"/>
                                    </Grid>
